{
  "name": "sigep-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "predev:e2e": "node ./scripts/free-port.mjs 3000",
    "dev:e2e": "next dev --webpack -H 127.0.0.1 -p 3000",
    "setup:start": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start.ps1",
    "setup:start:no-start": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start.ps1 -NoStart",
    "db:seed": "tsx src/db/seed.ts",
    "d1:sync": "tsx scripts/sync-d1-structure.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "postinstall": "node ./scripts/patch-jose.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:integration": "node ./scripts/run-integration-tests.mjs",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:smoke": "playwright test tests/e2e/smoke-auth-edit-history.spec.ts",
    "e2e:doctor": "node ./scripts/e2e-doctor.mjs",
    "e2e:seed:recovery": "node ./scripts/e2e-seed-recovery.mjs",
    "e2e:prepare": "npx playwright install chromium && npm run e2e:doctor"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "otpauth": "^9.5.0",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pg-mem": "^3.0.14",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "next": "16.1.6"
  }
}
